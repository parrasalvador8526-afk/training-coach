  "glossary": {
    "TUT": "Time Under Tension - tiempo bajo tensión por serie",
    "RPE": "Rate of Perceived Exertion - escala 1-10 de esfuerzo percibido",
    "RIR": "Reps In Reserve - repeticiones que quedan en el tanque",
    "Fallo": "Imposibilidad de completar una rep con técnica correcta",
    "Deload": "Semana de reducción de intensidad/volumen para recuperación",
    "Working Set": "Serie principal de trabajo con máxima intensidad",
    "Forced Reps": "Repeticiones asistidas después del fallo muscular",
    "Negativas": "Fase excéntrica con carga supramáxima",
    "Rest-Pause": "Micro descansos dentro de una serie para extenderla",
    "Pre-Exhaustion": "Técnica de fatigar primero con aislamiento",
    "Drop Set": "Reducir peso y continuar sin descanso",
    "Pump": "Congestión muscular por acumulación de sangre",
    "Fascia": "Tejido conectivo que envuelve el músculo",
    "Tempo": "Velocidad de ejecución (concéntrico-pausa-excéntrico)"
  }
}